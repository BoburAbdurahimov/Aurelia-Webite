# ─────────────────────────────────────────────────────────────────────────────
# Aurelia Grand Hotel — Social Auth Configuration
# Copy this file to .env.local and fill in your real credentials.
# Without these values, the app runs in DEMO mode (mock OAuth popups).
# ─────────────────────────────────────────────────────────────────────────────

# ── Google Sign-In ──────────────────────────────────────────────────────────
# 1. Go to: https://console.cloud.google.com/
# 2. Create a project → APIs & Services → Credentials
# 3. Create "OAuth 2.0 Client ID" → Web Application
# 4. Add your domain to "Authorised JavaScript origins" (e.g. https://your-hotel.vercel.app)
# 5. Copy the Client ID below:
VITE_GOOGLE_CLIENT_ID=

# ── Facebook Login ──────────────────────────────────────────────────────────
# 1. Go to: https://developers.facebook.com/apps/
# 2. Create an App → Add "Facebook Login" product
# 3. Settings → Basic → copy App ID:
VITE_FACEBOOK_APP_ID=

# ── Sign in with Apple ──────────────────────────────────────────────────────
# Requires an Apple Developer account ($99/yr)
# 1. Go to: https://developer.apple.com/account/resources/identifiers/list/serviceId
# 2. Create a "Services ID" (e.g. com.aureliagrand.web)
# 3. Enable "Sign In with Apple" and configure domains & return URLs
# 4. REDIRECT URI must be HTTPS (Apple does not allow localhost — use ngrok for dev)
VITE_APPLE_CLIENT_ID=
VITE_APPLE_REDIRECT_URI=https://your-hotel-domain.com/auth/apple/callback

# ─────────────────────────────────────────────────────────────────────────────
# How to activate:
# 1. cp .env.example .env.local
# 2. Fill in the values above
# 3. Restart dev server: npm run dev
# Social auth buttons will automatically switch from DEMO → LIVE mode.
# ─────────────────────────────────────────────────────────────────────────────

# ── Google Sheets API (Database) ────────────────────────────────────────────
# 1. Go to: https://console.cloud.google.com/
# 2. Create project → APIs & Services → Enable "Google Sheets API"
# 3. IAM → Service Accounts → Create → Download JSON key
# 4. Create a Google Spreadsheet and add 10 tabs:
#    Bookings, GuestOrders, GuestComplaints, GuestLostFound,
#    FolioItems, Invoices, Payments, Rooms, WorkOrders, Staff
# 5. Share the spreadsheet with the service account email (Editor access)
# 6. Fill in the values below:
GOOGLE_SHEETS_SPREADSHEET_ID=1ie82wx3lSXij6bKfOpKVAQaJXl7Jx5yiDgvEgLBHqYE
GOOGLE_SERVICE_ACCOUNT_EMAIL=aurelia-sheets@hotel-website-crm.iam.gserviceaccount.com
